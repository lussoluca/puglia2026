---
interface Structure {
    name: string;
    location: string;
    role: string;
    status?: string;
    phone?: string;
    whatsapp?: string;
    email?: string;
    url?: string;
    booking?: string;
    note?: string;
}

interface ContactsData {
    title: string;
    intro: string;
    structures: Structure[];
}

interface Props {
    contactsData: ContactsData;
}

const { contactsData } = Astro.props;
---

<section id="contacts" class="section">
    <div class="container">
        <h2 class="section-title">{contactsData.title}</h2>
        <p class="section-intro">{contactsData.intro}</p>
        <div class="contacts-grid">
            {contactsData.structures.map((s: Structure) => (
                <div class={`contact-card ${s.status === 'unavailable' ? 'contact-unavailable' : ''} ${s.status === 'toVerify' ? 'contact-to-verify' : ''}`}>
                    <div class="contact-header">
                        <h3>{s.status === 'unavailable' ? '\u274c' : s.status === 'toVerify' ? '\u2753' : '\u2705'} {s.name}</h3>
                        <span class="contact-role">{s.role}</span>
                    </div>
                    <div class="contact-body">
                        <p class="contact-location">{s.location}</p>
                        <div class="contact-details">
                            {s.phone && (
                                <p class="contact-item">
                                    <strong>Tel:</strong>{' '}
                                    <a href={`tel:${s.phone.replace(/\s/g, '')}`}>{s.phone}</a>
                                </p>
                            )}
                            {s.whatsapp && (
                                <p class="contact-item">
                                    <strong>WhatsApp:</strong>{' '}
                                    <a href={`https://wa.me/${s.whatsapp.replace(/[\s+]/g, '')}`} target="_blank" rel="noopener noreferrer">{s.whatsapp}</a>
                                </p>
                            )}
                            {s.email && (
                                <p class="contact-item">
                                    <strong>Email:</strong>{' '}
                                    <a href={`mailto:${s.email}`}>{s.email}</a>
                                </p>
                            )}
                            {s.url && (
                                <p class="contact-item">
                                    <strong>Sito:</strong>{' '}
                                    <a href={s.url} target="_blank" rel="noopener noreferrer">{s.url.replace(/^https?:\/\//, '').replace(/\/$/, '')}</a>
                                </p>
                            )}
                            {s.booking && (
                                <p class="contact-item">
                                    <a href={s.booking} target="_blank" rel="noopener noreferrer" class="contact-booking-link">Prenota online &rarr;</a>
                                </p>
                            )}
                        </div>
                        {s.note && (
                            <p class="contact-note">{s.note}</p>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>

<style>
    .contacts-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
        gap: 1.5rem;
        margin-top: 2rem;
    }

    .contact-card {
        background: var(--color-white, #fff);
        border-radius: 12px;
        overflow: hidden;
        box-shadow: 0 2px 12px rgba(0,0,0,0.08);
        transition: transform 0.2s, box-shadow 0.2s;
        border-left: 4px solid var(--color-nature, #27ae60);
    }

    .contact-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(0,0,0,0.1);
    }

    .contact-unavailable {
        border-left-color: var(--color-red, #e74c3c);
        opacity: 0.75;
    }

    .contact-to-verify {
        border-left-color: var(--color-accent, #e67e22);
    }

    .contact-header {
        padding: 1rem 1.2rem;
        border-bottom: 1px solid var(--color-border, #e0e4e8);
    }

    .contact-header h3 {
        margin: 0 0 0.3rem;
        font-size: 1.05rem;
    }

    .contact-role {
        font-size: 0.8rem;
        color: var(--color-text-light, #7f8c8d);
        font-weight: 500;
    }

    .contact-body {
        padding: 1.2rem;
    }

    .contact-location {
        margin: 0 0 0.8rem;
        font-weight: 500;
        color: var(--color-text-light, #555);
        font-size: 0.9rem;
    }

    .contact-details {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
    }

    .contact-item {
        font-size: 0.9rem;
        margin: 0;
        word-break: break-all;
    }

    .contact-item a {
        color: var(--color-primary, #1a5276);
        text-decoration: none;
    }

    .contact-item a:hover {
        text-decoration: underline;
    }

    .contact-booking-link {
        display: inline-block;
        margin-top: 0.3rem;
        color: var(--color-white, #fff) !important;
        background: var(--color-primary, #1a5276);
        padding: 0.3rem 0.8rem;
        border-radius: 6px;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .contact-booking-link:hover {
        background: var(--color-primary-light, #2980b9);
        text-decoration: none !important;
    }

    .contact-note {
        margin-top: 0.8rem;
        padding-top: 0.8rem;
        border-top: 1px solid #eee;
        font-size: 0.85rem;
        color: var(--color-text-light, #7f8c8d);
        line-height: 1.5;
        font-style: italic;
    }
</style>
