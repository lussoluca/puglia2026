---
import itinerary from '../data/itinerary.json';

const base = import.meta.env.BASE_URL;

const tagClasses: Record<string, string> = {
    travel: 'tag-travel',
    sea: 'tag-sea',
    nature: 'tag-nature',
    culture: 'tag-culture',
};

const tagLabels: Record<string, string> = {
    travel: 'Viaggio',
    sea: 'Mare',
    nature: 'Natura',
    culture: 'Cultura',
};
---

<section id="itinerary" class="section">
    <div class="container">
        <h2 class="section-title">Itinerario Giorno per Giorno</h2>
        <div class="timeline">
            {itinerary.map((day) => (
                <div class="timeline-item" data-day={day.day}>
                    <div class="timeline-marker">
                        <span class="day-number">G{day.day}</span>
                    </div>
                    <div class="timeline-content">
                        <div class="timeline-header">
                            <h3>{new Date(day.date).toLocaleDateString('it-IT', { weekday: 'long' })} {new Date(day.date).getDate()} {new Date(day.date).toLocaleDateString('it-IT', { month: 'long' })}</h3>
                            {day.tags.map(tag => (
                                <span class={`timeline-tag ${tagClasses[tag]}`}>{tagLabels[tag]}</span>
                            ))}
                        </div>
                        <h4 set:html={day.title.replace(/→/g, '&rarr;')} />
                        <a href={`${base}day/${day.day}/`} class="day-detail-link">Vedi dettagli giornata &rarr;</a>
                        
                        {day.travelInfo && (
                            <p class="travel-info">{day.travelInfo}</p>
                        )}
                        
                        {day.description && (
                            <div class="day-details">
                                <p>{day.description}</p>
                            </div>
                        )}
                        
                        <div class="day-details">
                            {day.activities.map(act => (
                                <div class="day-activity">
                                    <span class="activity-icon">{act.icon}</span>
                                    <div>
                                        <strong>{act.title}</strong> - {act.text}
                                        {act.url && (
                                            <a href={act.url} target="_blank" rel="noopener noreferrer" class="ext-link" title="Apri in Google Maps">Vedi sulla mappa &rarr;</a>
                                        )}
                                    </div>
                                </div>
                            ))}
                        </div>
                        
                        {day.highlights && (
                            <div class="poi-box">
                                <h5>Da non perdere al Gargano</h5>
                                <ul>
                                    {day.highlights.map(h => {
                                        const text = typeof h === 'string' ? h : h.text;
                                        const url = typeof h === 'string' ? null : h.url;
                                        const parts = text.split(' - ');
                                        return (
                                            <li>
                                                <strong>{parts[0]}</strong>{parts.length > 1 ? ' - ' + parts.slice(1).join(' - ') : ''}
                                                {url && (
                                                    <a href={url} target="_blank" rel="noopener noreferrer" class="ext-link">Info &rarr;</a>
                                                )}
                                            </li>
                                        );
                                    })}
                                </ul>
                            </div>
                        )}
                        
                        {day.campsite && (
                            <div class="campsite-box">
                                <h5>&#9978; Campeggio ({day.campsite.nightsLabel})</h5>
                                <p>
                                    <strong>{day.campsite.name}</strong> - {day.campsite.location}
                                    {day.campsite.url && (
                                        <a href={day.campsite.url} target="_blank" rel="noopener noreferrer" class="ext-link">Sito web &rarr;</a>
                                    )}
                                </p>
                                <p class="campsite-detail">{day.campsite.detail}</p>
                                <p class="campsite-alt">
                                    Alternativa: <strong>{day.campsite.alternative.split(' - ')[0]}</strong> - {day.campsite.alternative.split(' - ').slice(1).join(' - ')}
                                    {day.campsite.alternativeUrl && (
                                        <a href={day.campsite.alternativeUrl} target="_blank" rel="noopener noreferrer" class="ext-link">Vedi &rarr;</a>
                                    )}
                                </p>
                            </div>
                        )}
                    </div>
                </div>
            ))}
        </div>
    </div>
</section>
