---
import defaultBudget from '../data/budget.json';
import defaultCamper from '../data/camper.json';

const budget = Astro.props.budgetData || defaultBudget;
const camper = Astro.props.hideCamperLink ? null : defaultCamper;
const summaryTitle = Astro.props.summaryTitle || 'Totale stimato (escluso noleggio camper)';

const fuelDate = budget.fuelPrice?.date
    ? new Date(budget.fuelPrice.date).toLocaleDateString('it-IT', { day: 'numeric', month: 'long', year: 'numeric' })
    : null;
---

<section id="budget" class="section">
    <div class="container">
        <h2 class="section-title">Budget Indicativo</h2>
        <p class="section-intro">Stima dei costi principali per il viaggio. I prezzi sono indicativi e possono variare.</p>

        <div class="budget-grid">
            {budget.categories.map(cat => (
                <div class="budget-card">
                    <h3>{cat.title}</h3>
                    <p class="budget-detail">{cat.detail}</p>
                    <ul>
                        {cat.items.map(item => (
                            <li>{item}</li>
                        ))}
                    </ul>
                    <span class="budget-total">{cat.total}</span>
                    {cat.title === 'Carburante' && budget.fuelPrice && (
                        <p class="fuel-source">
                            Dato aggiornato al {fuelDate} &middot;
                            <a href={budget.fuelPrice.sourceUrl} target="_blank" rel="noopener noreferrer">
                                Fonte: MIMIT
                            </a>
                        </p>
                    )}
                </div>
            ))}
        </div>

        <div class="budget-summary">
            <h3>{summaryTitle}</h3>
            <p class="budget-grand-total">{budget.grandTotal}</p>
            <p class="budget-note">
                {camper ? (
                    <Fragment>
                        {budget.grandTotalNote.split('Roadsurfer')[0]}
                        <a href={camper.url} target="_blank">Roadsurfer</a>
                        {budget.grandTotalNote.split('Roadsurfer').slice(1).join('Roadsurfer')}
                    </Fragment>
                ) : (
                    budget.grandTotalNote
                )}
            </p>
        </div>
    </div>
</section>
