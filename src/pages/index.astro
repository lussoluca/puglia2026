---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Overview from '../components/Overview.astro';
import Camper from '../components/Camper.astro';
import Itinerary from '../components/Itinerary.astro';
import Map from '../components/Map.astro';
import Beaches from '../components/Beaches.astro';
import Restaurants from '../components/Restaurants.astro';
import Events from '../components/Events.astro';
import Budget from '../components/Budget.astro';
import Weather from '../components/Weather.astro';
import Gallery from '../components/Gallery.astro';
import Checklist from '../components/Checklist.astro';
import Tips from '../components/Tips.astro';

const base = import.meta.env.BASE_URL;
---

<Layout title="Puglia 2026 - Vacanza in Camper">
    <div class="variant-banner variant-banner-camper">
        <div class="container">
            <span class="variant-badge">🚐 Versione Camper</span>
            <span class="variant-text">In camper da Torino, 13 giorni di avventura</span>
            <a href={`${base}auto/`} class="variant-link">Vedi versione Auto (B&B) &rarr;</a>
        </div>
    </div>
    <Hero />
    <Overview />
    <Camper />
    <Itinerary />
    <Map />
    <Beaches />
    <Restaurants />
    <Events />
    <Gallery />
    <Budget />
    <Weather />
    <Checklist />
    <Tips />
</Layout>

<style>
    .variant-banner-camper {
        background: linear-gradient(135deg, #1a5276, #2980b9);
        color: white;
        padding: 0.8rem 0;
        text-align: center;
        position: relative;
        z-index: 5;
    }

    .variant-banner-camper .container {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .variant-badge {
        background: rgba(255,255,255,0.2);
        padding: 0.3rem 0.8rem;
        border-radius: 20px;
        font-weight: 700;
        font-size: 0.9rem;
    }

    .variant-text {
        font-size: 0.9rem;
        opacity: 0.95;
    }

    .variant-link {
        color: white;
        text-decoration: underline;
        font-size: 0.85rem;
        font-weight: 600;
    }

    .variant-link:hover {
        opacity: 0.8;
    }
</style>
